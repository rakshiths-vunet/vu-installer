primary_images:
  location: "https://ghcr.io"
  username: "CPQPQ8bQ7W5Krv68CvZJ6w=="
  password: "Nf0oY7eKPCDtzVBnFQpKYRp6ZL3SgD3B56R5jyuFye4lSzLiwfEIrMJfkT0ntoZQ"
  email: "devsecops@vunetsystems.com"

sizing:
  category:
    - "data-store-optimised"
    - "data-hub-optimised"
    - "core-services-optimised"

  env_name: "vm"

  node:
    - ip_address: "{{ private_ip }}"
      is_master: true
      storage:
        default: ["/data1"]
        host: ["/data1"]

  # vustream & vublock related components
  deployments:
    - name: pipeline
      resource_limit:
        min:
          cpu: "0.1"
          memory: "128Mi"
        max:
          cpu: "0.5"
          memory: "256Mi"

  # service information
  services:
    # longhorn
    - name: "longhorn"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "2Gi"
      replica: 1
      disk:
        default: 2Gi

    # minio-operator
    - name: "minio-operator"
      resource_limit:
        min:
          cpu: "0.2"
          memory: "500Mi"
        max:
          cpu: "0.3"
          memory: "1Gi"
      replica: 1

    # minio-tenant
    - name: "minio-tenant"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "1Gi"
      replica: 1
      disk:
        host: 20Gi
      pv_mapper:
        - name: "minio-tenant"
          size: "20Gi"
          hostPath: "/data1"
          nodeName: "{{ node_hostname }}"
          nodeIP: "{{ private_ip }}"
          dirPath: "minio"
          storageClass: "local-storage"

    # postgresql
    - name: "postgresql"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "2Gi"
      replica: 1
      disk:
        default: 10Gi

    # kafka-broker
    - name: "kafka-broker"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.75"
          memory: "2Gi"
      replica: 1
      disk:
        host: 5Gi
      pv_mapper: 
        - name: "0"
          size: "12Gi"
          hostPath: "/data1"
          nodeName: "{{ node_hostname }}"
          nodeIP: "{{ private_ip }}"
          dirPath: "kafka_dir"
        
    # kafka-zookeeper
    - name: "kafka-zookeeper"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.75"
          memory: "2Gi"
      replica: 1
      disk:
        host: 4Gi
      pv_mapper:
        - name: "datalogdir-kafka-cluster-cp-zookeeper-0"
          size: "5Gi"
          storageClass: "local-storage"
          hostPath: "/data1"
          dirPath: "zookeeper-log"
          nodeName: "{{ node_hostname }}"
          nodeIP: "{{ private_ip }}"
        - name: "datadir-kafka-cluster-cp-zookeeper-0"
          size: "5Gi"
          storageClass: "local-storage"
          hostPath: "/data1"
          dirPath: "kafka_zookeeper_dir"
          nodeName: "{{ node_hostname }}"
          nodeIP: "{{ private_ip }}"
    # kafka-connect
    - name: "kafka-connect"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "2Gi"
      replica: 1

    # clickhouse-operator
    - name: "ch-operator"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "2Gi"
      replica: 1

    # clickhouse-keeper
    - name: "ch-keeper"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "2Gi"
      replica: 1
      disk:
        host: 5Gi
      pv_mapper: 
        - name: "0"
          size: "6Gi"
          hostPath: "/data1"
          nodeName: "{{ node_hostname }}"
          nodeIP: "{{ private_ip }}"
          dirPath: "clickhouse-keeper"

    # clickhouse database
    - name: "ch-database"
      resource_limit:
        min:
          cpu: "2"
          memory: "500Mi"
        max:
          cpu: "4"
          memory: "6Gi"
      replica: 1
      disk:
        host: 5Gi
      pv_mapper: 
        - name: "warm-chi-clickhouse-vusmart-0-0-0"
          size: "12Gi"
          hostPath: "/data1"
          nodeName: "{{ node_hostname }}"
          nodeIP: "{{ private_ip }}"
          dirPath: "clickhouse-warm"

        - name: "clickhouse-data-volume-chi-clickhouse-vusmart-0-0-0"
          size: "12Gi"
          hostPath: "/data1"
          nodeName: "{{ node_hostname }}"
          nodeIP: "{{ private_ip }}"
          dirPath: "clickhouse"

      config_override:
        persistence.host.encrypted: "true"
        persistence.host.hot.enabled: "true"
        #update this value to false, if WARM is disabled
        persistence.host.warm.enabled: "true"
        #update this value to false, if COLD is disabled
        persistence.cold.enabled: "true"

    # telegraf-vusmart
    - name: "telegraf-vusmart"
      resource_limit:
        min:
          cpu: "0.1"
          memory: "250Mi"
        max:
          cpu: "0.3"
          memory: "500Mi"
      replica: 1

    # telegraf-infra
    - name: "telegraf-infra"
      resource_limit:
        min:
          cpu: "0.2"
          memory: "250Mi"
        max:
          cpu: "0.5"
          memory: "500Mi"
      replica: 1

    # redis
    - name: "redis"
      resource_limit:
        min:
          cpu: "0.2"
          memory: "500Mi"
        max:
          cpu: "0.3"
          memory: "2Gi"
      replica: 1
      
    # orchestration
    - name: "orchestrator"
      resource_limit:
        min:
          cpu: "0.1"
          memory: "250Mi"
        max:
          cpu: "0.2"
          memory: "500Mi"
      replica: 1
    
    # docusaurus
    - name: "docusaurus"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "1Gi"
      replica: 1  

    # fluentbit
    - name: "fluentbit"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "1Gi"
      replica: 1
    
    # traefik
    - name: "traefik"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "2Gi"
      replica: 1

    # renderer-service
    - name: "nairobi-renderer"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "3"
          memory: "4Gi"
      replica: 1

    # reporter service
    - name: "nairobi-reporter"
      resource_limit:
        min:
          cpu: "0.2"
          memory: "500Mi"
        max:
          cpu: "0.3"
          memory: "2Gi"
      replica: 1

    # nairobi
    - name: "nairobi-app"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "2Gi"
      replica: 1
      disk:
        default: 2Gi
      config_override:
        address.public: "{{ private_ip }}/vui"

    # keycloak
    - name: "keycloak"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "2Gi"
      replica: 1
      
    # denver
    - name: "denver"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "4Gi"
      replica: 1

    # vuinterface
    - name: "vuinterface"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "4Gi"
      replica: 1
      config_override:
        env.0.value: "{{ private_ip }}"
        env.1.value: "{{ private_ip }}"
        #Update the DISK Names accordingly as per HOT and WARM and update the disk name, if the encryption isn't enabled
        env.2.value: "default_encrypted_disk"
        env.3.value: "warm_encrypted_disk"
        
    # dao
    - name: "dao"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "4Gi"
      replica: 1
      config_override:
        env.0.value: "{{ private_ip }}"
        env.1.value: "{{ private_ip }}"
        #Update the DISK Names accordingly as per HOT and WARM and update the disk name, if the encryption isn't enabled
        env.2.value: "default_encrypted_disk"
        env.3.value: "warm_encrypted_disk"

    # alert
    - name: "alert"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "1Gi"
      replica: 1
      config_override:
        env.0.value: "{{ private_ip }}"
        env.1.value: "{{ private_ip }}"
     
    #vublock-service
    - name: "vublock"
      resource_limit:
        min:
          cpu: "0.3"
          memory: "500Mi"
        max:
          cpu: "0.5"
          memory: "2Gi"
      replica: 1   
      
    #vublock-store 
    - name: "vublock-store"
      resource_limit:
        min:
          cpu: "0.2"
          memory: "250Mi"
        max:
          cpu: "0.3"
          memory: "500Mi"
      replica: 1
      
    # post-jobs
    - name: "post-jobs"
      resource_limit:
        min:
          cpu: "0.2"
          memory: "250Mi"
        max:
          cpu: "0.3"
          memory: "500Mi"
      replica: 1
